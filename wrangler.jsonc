{
  "name": "gentoozh-web",
  "compatibility_date": "2026-06-01",
  "workers_dev": false,
  "routes": [
    { "pattern": "gentoozh.org", "custom_domain": true },
    { "pattern": "web.gentoozh.org", "custom_domain": true }
  ],
  "assets": {
    "directory": "./public",
    "not_found_handling": "404-page",
    "html_handling": "auto-trailing-slash"
  }
}
